# ============================================================
# NEXLIN GHL — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit your real .env file to version control.
# ============================================================

# ─── Database ───────────────────────────────────────────────
# PostgreSQL connection string (required)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/nexlin_db?schema=public"

# ─── Authentication (NextAuth) ──────────────────────────────
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-nextauth-key"
NEXTAUTH_URL="http://localhost:3000"

# ─── App URL ────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── AI Providers ───────────────────────────────────────────
# At least ONE key is required for AI features to work.
# The system automatically picks the best available model for each task.

# Google Gemini (default / fastest for chat)
# Get your key at: https://aistudio.google.com/
GOOGLE_GENERATIVE_AI_API_KEY="AIza..."

# OpenAI (best for email marketing copy)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-..."

# Anthropic Claude (best for landing pages / workflows)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY="sk-ant-..."

# ─── SMS / Voice (Twilio) ───────────────────────────────────
# Required for real SMS sending and Voice AI features.
# Get your credentials at: https://console.twilio.com/
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your_twilio_auth_token"
TWILIO_PHONE_NUMBER="+15551234567"

# ─── Email (Resend) ─────────────────────────────────────────
# Required for real email campaign delivery.
# Get your key at: https://resend.com/api-keys
RESEND_API_KEY="re_xxxxxxxx"
RESEND_FROM_DOMAIN="yourdomain.com"

# ─── Payments (Stripe) ──────────────────────────────────────
# Required for subscription billing (agency plans).
# Get your keys at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_PUBLISHABLE_KEY="pk_live_..."
# Stripe Webhook Secret — get from: https://dashboard.stripe.com/webhooks
# Point your webhook to: https://yourdomain.com/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET="whsec_..."
# Price ID for your subscription plan (create in Stripe Dashboard)
STRIPE_PRICE_ID="price_..."

# ─── Payments (Paystack) ────────────────────────────────────
# Optional: Alternative payment processor for African markets.
# Get your keys at: https://dashboard.paystack.com/#/settings/developer
PAYSTACK_SECRET_KEY="sk_live_..."
PAYSTACK_PUBLIC_KEY="pk_live_..."

# ─── Real-time (Pusher) ─────────────────────────────────────
# Required for real-time inbox & notifications.
# Get your credentials at: https://pusher.com/
PUSHER_APP_ID="your_pusher_app_id"
PUSHER_KEY="your_pusher_key"
PUSHER_SECRET="your_pusher_secret"
PUSHER_CLUSTER="us2"
NEXT_PUBLIC_PUSHER_KEY="your_pusher_key"
NEXT_PUBLIC_PUSHER_CLUSTER="us2"

# ─── Background Jobs (Inngest) ──────────────────────────────
# Optional: For scheduled workflows and async job processing.
# Get your key at: https://app.inngest.com/
INNGEST_EVENT_KEY="your_inngest_event_key"
INNGEST_SIGNING_KEY="your_inngest_signing_key"

# ─── File Uploads (Optional) ────────────────────────────────
# For media library uploads. Options: AWS S3, Cloudflare R2, Vercel Blob
# Example using Vercel Blob:
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# ─── OAuth Providers (Optional) ─────────────────────────────
# Social login for agency users
GOOGLE_CLIENT_ID="your_google_oauth_client_id"
GOOGLE_CLIENT_SECRET="your_google_oauth_client_secret"
