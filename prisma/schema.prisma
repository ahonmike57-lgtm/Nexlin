// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Platform {
  id        String   @id @default(cuid())
  name      String   @default("NEXLIN GHL")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  agencies  Agency[]
}

model Agency {
  id                String   @id @default(cuid())
  platformId        String
  platform          Platform @relation(fields: [platformId], references: [id], onDelete: Cascade)
  name              String
  subdomain         String   @unique
  customDomain      String?  @unique
  whiteLabelName    String?
  logoUrl           String?
  brandColors       String? // JSON string
  loginBackgroundImage String?
  missedCallEnabled Boolean  @default(false)
  missedCallMessage String?  @default("Hi, this is [Agency Name]. We missed your call, how can we help?")
  
  planTier          String   @default("basic")
  status            String   @default("active") // trialing, active, past_due, suspended, churned
  stripeCustomerId  String?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  users             User[]
  subAgencies       SubAgency[]
  contacts          Contact[]
  deals             Deal[]
  subscriptions     Subscription[]
  funnels           Funnel[]
  conversations     Conversation[]
  campaigns         Campaign[]
  workflows         Workflow[]
  appointments      Appointment[]
  phoneNumbers      PhoneNumber[]
  portRequests      PortRequest[]
  tickets           Ticket[]
  articles          KnowledgeArticle[]
  agents            VoiceAgent[]
  socialAccounts    SocialAccount[]
  mcpConnections    McpConnection[]
  tenantApps        TenantApp[]
  formSubmissions   FormSubmission[]
  mediaFiles        MediaFile[]
  SocialPost        SocialPost[]
  AdCampaign        AdCampaign[]
  Review            Review[]
  ReviewRequest     ReviewRequest[]
  Form              Form[]
  pipelines         Pipeline[]
  aiSettings        AiSettings[]
  webhooks          Webhook[]
  
  // Phase 1 Relations
  snapshots         Snapshot[]
  rebillingMarkups  RebillingMarkup[]
  affiliates        Affiliate[]
}

model SubAgency {
  id          String   @id @default(cuid())
  name        String
  email       String
  phoneNumber String?
  agencyId    String
  agency      Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  deals         Deal[]
  appointments  Appointment[]
  contacts      Contact[]
  pipelines     Pipeline[]
  funnels       Funnel[]
  conversations Conversation[]
  workflows     Workflow[]
  users         User[]
}

model User {
  id            String     @id @default(cuid())
  email         String?    @unique
  passwordHash  String?
  name          String?
  role          String     @default("Business Owner") // Super Admin, Agency Owner, Business Owner, Team Member
  country       String?
  isAfricaUser  Boolean    @default(false)
  agencyId      String?
  agency        Agency?    @relation(fields: [agencyId], references: [id])
  subAgencyId   String?
  subAgency     SubAgency? @relation(fields: [subAgencyId], references: [id])
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  auditLogs     AuditLog[]
  installedApps TenantApp[]
}

model Contact {
  id          String     @id @default(cuid())
  agencyId    String
  agency      Agency     @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  firstName   String
  lastName    String?
  email       String?
  phone       String?
  company     String?
  subAgencyId String?
  subAgency   SubAgency? @relation(fields: [subAgencyId], references: [id])
  leadScore   Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  deals           Deal[]
  conversations   Conversation[]
  appointments    Appointment[]
  tickets         Ticket[]
  reviews         Review[]
  reviewRequests  ReviewRequest[]
  formSubmissions FormSubmission[]
}

model Deal {
  id          String         @id @default(cuid())
  agencyId    String
  agency      Agency         @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  subAgencyId String?
  subAgency   SubAgency?     @relation(fields: [subAgencyId], references: [id])
  contactId   String?
  contact     Contact?       @relation(fields: [contactId], references: [id], onDelete: SetNull)
  pipelineId  String?
  pipeline    Pipeline?      @relation(fields: [pipelineId], references: [id], onDelete: SetNull)
  stageId     String?
  stageObj    PipelineStage? @relation(fields: [stageId], references: [id], onDelete: SetNull)
  title       String
  value       Float          @default(0)
  stage       String // Legacy string stage for backward compatibility
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model Pipeline {
  id          String          @id @default(cuid())
  agencyId    String
  agency      Agency          @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  name        String
  subAgencyId String?
  subAgency   SubAgency?      @relation(fields: [subAgencyId], references: [id])
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  stages      PipelineStage[]
  deals       Deal[]
}

model PipelineStage {
  id         String   @id @default(cuid())
  pipelineId String
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  name       String
  color      String?  @default("bg-primary/20 text-primary border-primary/30")
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deals      Deal[]
}

model Subscription {
  id                   String    @id @default(cuid())
  agencyId             String
  agency               Agency    @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  paymentProcessor     String // "stripe" or "paystack"
  stripeCustomerId     String?
  stripeSubscriptionId String?
  paystackCode         String?
  paystackEmail        String?
  status               String // "active", "past_due", "cancelled"
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  transactions PaymentTransaction[]
}

model PaymentTransaction {
  id                     String       @id @default(cuid())
  subscriptionId         String
  subscription           Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  amount                 Float
  currency               String
  status                 String // "pending", "succeeded", "failed", "refunded"
  processor              String
  processorTransactionId String?
  processorFee           Float?
  netAmount              Float?
  errorMessage           String?
  processedAt            DateTime?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String
  entity    String
  entityId  String
  details   String? // JSON string
  createdAt DateTime @default(now())
}

// --- NextAuth Models ---

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- Phase 2 Feature Models ---

model Funnel {
  id           String     @id @default(cuid())
  agencyId     String
  agency       Agency     @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  name         String
  subdomain    String?    @unique
  customDomain String?    @unique
  subAgencyId  String?
  subAgency    SubAgency? @relation(fields: [subAgencyId], references: [id])
  status       String     @default("draft") // draft, active, archived
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  steps FunnelStep[]
}

model FunnelStep {
  id        String   @id @default(cuid())
  funnelId  String
  funnel    Funnel   @relation(fields: [funnelId], references: [id], onDelete: Cascade)
  name      String
  path      String
  order     Int
  content   String? // JSON string containing builder blocks
  config    String? // JSON string for configuration (e.g., email subject, wait time)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([funnelId, path])
}

model Conversation {
  id          String     @id @default(cuid())
  agencyId    String
  agency      Agency     @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  contactId   String
  contact     Contact    @relation(fields: [contactId], references: [id], onDelete: Cascade)
  channel     String // email, sms, whatsapp
  subAgencyId String?
  subAgency   SubAgency? @relation(fields: [subAgencyId], references: [id])
  status      String     @default("open") // open, closed
  aiAutoReply Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  messages Message[]
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  isOutbound     Boolean      @default(false)
  content        String
  status         String       @default("sent") // sent, delivered, read, failed
  createdAt      DateTime     @default(now())
}

model Campaign {
  id        String    @id @default(cuid())
  agencyId  String
  agency    Agency    @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  name      String
  subject   String
  content   String // HTML/JSON
  status    String    @default("draft") // draft, scheduled, sending, completed
  sentAt    DateTime?
  createdAt DateTime  @default(now())
}

// --- Phase 6 Feature Models ---

model Workflow {
  id          String     @id @default(cuid())
  agencyId    String
  agency      Agency     @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  name        String
  subAgencyId String?
  subAgency   SubAgency? @relation(fields: [subAgencyId], references: [id])
  status      String     @default("draft") // draft, active
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  triggers WorkflowTrigger[]
  actions  WorkflowAction[]
}

model WorkflowTrigger {
  id         String   @id @default(cuid())
  workflowId String
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  type       String // e.g. "contact_created", "form_submitted", "tag_added"
  config     String? // JSON string
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model WorkflowAction {
  id         String   @id @default(cuid())
  workflowId String
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  type       String // e.g. "send_email", "add_tag", "create_task"
  order      Int      @default(0)
  config     String? // JSON string
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Appointment {
  id          String     @id @default(cuid())
  title       String
  startTime   DateTime
  endTime     DateTime
  contactId   String
  contact     Contact    @relation(fields: [contactId], references: [id])
  agencyId    String
  agency      Agency     @relation(fields: [agencyId], references: [id])
  createdAt   DateTime   @default(now())
  SubAgency   SubAgency? @relation(fields: [subAgencyId], references: [id])
  subAgencyId String?
}

model PhoneNumber {
  id        String   @id @default(cuid())
  agencyId  String
  agency    Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  number    String   @unique
  status    String   @default("active") // active, porting, inactive
  provider  String   @default("twilio")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PortRequest {
  id             String   @id @default(cuid())
  agencyId       String
  agency         Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  numberToPort   String
  currentCarrier String
  accountNumber  String?
  accountPin     String?
  status         String   @default("pending") // pending, approved, rejected, completed
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Ticket {
  id          String   @id @default(cuid())
  agencyId    String
  agency      Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  contactId   String?
  contact     Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  title       String
  description String?
  status      String   @default("open") // open, pending, resolved, closed
  priority    String   @default("normal") // low, normal, high, urgent
  assignedTo  String? // userId
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model KnowledgeArticle {
  id        String   @id @default(cuid())
  agencyId  String
  agency    Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  title     String
  content   String // HTML or Markdown
  category  String   @default("general")
  status    String   @default("draft") // draft, published
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VoiceAgent {
  id           String   @id @default(cuid())
  agencyId     String
  agency       Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  name         String
  systemPrompt String?
  voiceId      String? // e.g. elevenlabs voice id
  greeting     String?
  isActive     Boolean  @default(false)
  missedCallEnabled    Boolean  @default(false)
  missedCallMessage    String?  @default("Hi, sorry we missed your call. How can we help you today?")
  missedCallAIFollowUp Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model SocialAccount {
  id          String   @id @default(cuid())
  agencyId    String
  agency      Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  platform    String // facebook, instagram, linkedin, twitter
  handle      String
  accessToken String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  posts SocialPost[]
}

model SocialPost {
  id           String        @id @default(cuid())
  agencyId     String
  agency       Agency        @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  accountId    String
  account      SocialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  content      String
  mediaUrls    String? // JSON array
  status       String        @default("scheduled") // draft, scheduled, published, failed
  scheduledFor DateTime?
  publishedAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model AdCampaign {
  id          String   @id @default(cuid())
  agencyId    String
  agency      Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  platform    String // google, facebook, tiktok
  name        String
  status      String   @default("active") // active, paused, completed
  budget      Float    @default(0)
  spend       Float    @default(0)
  impressions Int      @default(0)
  clicks      Int      @default(0)
  conversions Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// --- Phase 12 Feature Models ---

model Review {
  id         String   @id @default(cuid())
  agencyId   String
  agency     Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  contactId  String?
  contact    Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  platform   String // google, facebook, yelp
  rating     Int
  content    String?
  authorName String
  url        String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ReviewRequest {
  id        String   @id @default(cuid())
  agencyId  String
  agency    Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  channel   String // email, sms
  status    String   @default("sent") // sent, delivered, opened, clicked, reviewed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Form {
  id        String   @id @default(cuid())
  agencyId  String
  agency    Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  name      String
  fields    String // JSON array of field definitions
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  submissions FormSubmission[]
}

model FormSubmission {
  id        String   @id @default(cuid())
  formId    String
  form      Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  agencyId  String
  agency    Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  data      String // JSON object of submitted data
  createdAt DateTime @default(now())
}

model MediaFile {
  id        String   @id @default(cuid())
  agencyId  String
  agency    Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  name      String
  url       String
  size      Int // in bytes
  type      String // image/jpeg, video/mp4, application/pdf
  folder    String? // optional logical folder
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- Native Integrations & Webhooks ---

model Webhook {
  id        String   @id @default(cuid())
  agencyId  String
  agency    Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  name      String
  url       String
  event     String   // e.g., "contact.created", "deal.won", "form.submitted"
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- MCP & Apps Models ---

model McpConnection {
  id                   String   @id @default(cuid())
  agencyId             String
  agency               Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  name                 String
  serverUrl            String
  encryptedCredentials String?
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model App {
  id           String   @id // e.g. slug (google-business)
  name         String
  category     String
  tagline      String?
  description  String?
  icon         String?
  installType  String   // "oauth", "apikey", "webhook", "config", "number"
  configSchema String?  // JSON string
  badge        String?
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  installs     TenantApp[]
}

model TenantApp {
  id          String   @id @default(cuid())
  agencyId    String
  agency      Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  appId       String
  app         App      @relation(fields: [appId], references: [id], onDelete: Cascade)
  status      String   @default("active") // active, error, disabled
  config      String?  // JSON string, encrypted
  installedBy String?
  user        User?    @relation(fields: [installedBy], references: [id], onDelete: SetNull)
  installedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([agencyId, appId])
}

// --- Phase 1 Enterprise Features (Agency Growth Engine) ---

// 1. Snapshots
model Snapshot {
  id          String   @id @default(cuid())
  agencyId    String
  agency      Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  name        String
  description String?
  version     String   @default("1.0.0")
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  assets      SnapshotAsset[]
}

model SnapshotAsset {
  id         String   @id @default(cuid())
  snapshotId String
  snapshot   Snapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  type       String   // "funnel", "workflow", "email_template", "pipeline", "custom_values"
  sourceId   String   // ID of the original asset
  data       String   // JSON stringified export of the asset
  createdAt  DateTime @default(now())
}

// 2. SaaS Mode & Re-billing
model BillingWallet {
  id          String   @id @default(cuid())
  agencyId    String?
  subAgencyId String?
  balance     Float    @default(0.0) // Credits available
  currency    String   @default("usd")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  usageLogs   UsageLog[]
  
  @@unique([agencyId])
  @@unique([subAgencyId])
}

model UsageLog {
  id          String         @id @default(cuid())
  walletId    String
  wallet      BillingWallet  @relation(fields: [walletId], references: [id], onDelete: Cascade)
  type        String         // "sms", "email", "ai_tokens", "call_minutes"
  amount      Float          // Raw usage amount (e.g. 1 sms, 150 tokens)
  cost        Float          // Actual cost
  markup      Float          // The cost charged to the sub-account (cost * agency markup)
  description String?
  createdAt   DateTime       @default(now())
}

model RebillingMarkup {
  id          String   @id @default(cuid())
  agencyId    String
  agency      Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  type        String   // "sms", "email", "ai_tokens", "call_minutes"
  multiplier  Float    @default(1.0) // e.g. 1.5x
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([agencyId, type])
}

// 3. Affiliate Manager
model Affiliate {
  id          String   @id @default(cuid())
  agencyId    String
  agency      Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  name        String
  email       String   @unique
  paypalEmail String?
  status      String   @default("active") // active, suspended
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  links       AffiliateLink[]
  payouts     CommissionPayout[]
}

model AffiliateLink {
  id          String    @id @default(cuid())
  affiliateId String
  affiliate   Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  code        String    @unique // e.g. ?ref=XYZ123
  targetUrl   String
  clicks      Int       @default(0)
  conversions Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model CommissionPayout {
  id          String    @id @default(cuid())
  affiliateId String
  affiliate   Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  amount      Float
  status      String    @default("pending") // pending, paid, failed
  paidAt      DateTime?
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model AiSettings {
  id        String   @id @default(cuid())
  agencyId  String
  agency    Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  provider  String   // "google", "openai", "anthropic"
  apiKey    String   // Encrypted or plain text key
  modelName String   // "gpt-4o", "gemini-1.5-pro", etc.
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([agencyId, provider])
}

model PlatformAdmin {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  role         String    @default("owner") // owner, developer, support
  passwordHash String?
  createdAt    DateTime  @default(now())
  lastLoginAt  DateTime?
}
